# ── Copy this file to ".env" and fill in your real values ──

# Database — SQLite file, no setup needed. Leave as-is to start.
DATABASE_URL="file:./dev.db"

# Payment mode: "upi_qr" (active now, no fees, you confirm manually)
# Switch to "razorpay" later when you grow — no code changes needed.
NEXT_PUBLIC_PAYMENT_MODE="upi_qr"

# Clerk (admin login) — from dashboard.clerk.com → Configure → API Keys
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY="pk_test_xxxxxxxxxxxx"
CLERK_SECRET_KEY="sk_test_xxxxxxxxxxxx"
NEXT_PUBLIC_CLERK_SIGN_IN_URL="/sign-in"

# Razorpay — ONLY needed if/when you set PAYMENT_MODE to "razorpay".
# Leave blank for now. Get from dashboard.razorpay.com → Settings → API Keys.
RAZORPAY_KEY_ID=""
RAZORPAY_KEY_SECRET=""

# UPI & WhatsApp settings for payment QR (UPI mode)
NEXT_PUBLIC_UPI_ID="your-upi-id@bank"
NEXT_PUBLIC_UPI_NAME="Your Name"
NEXT_PUBLIC_WHATSAPP_NUMBER="911234567890"
